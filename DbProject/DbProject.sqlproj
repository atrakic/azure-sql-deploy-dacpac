<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="2.1.0" />
  <PropertyGroup>
    <Name>DbProject</Name>
    <DSP>Microsoft.Data.Tools.Schema.Sql.Sql160DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
  </PropertyGroup>
  <ItemGroup>
    <Build Include="dbo\Tables\DimCustomer.sql" />
    <Build Include="dbo\Tables\DimDate.sql" />
    <Build Include="dbo\Tables\DimProduct.sql" />
    <Build Include="dbo\Tables\FactSalesOrder.sql" />
    <Build Include="dbo\Views\vSalesByCityAndCategory.sql" />
  </ItemGroup>
</Project>
